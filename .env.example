# PayPal (developer.paypal.com → Apps & Credentials)
PAYPAL_CLIENT_ID=tu_client_id
# OBLIGATORIA (mínimo 16 caracteres) — el servidor no arranca sin ella
PAYPAL_CLIENT_SECRET=tu_secret
PAYPAL_MODE=sandbox            # sandbox | live

# NOWPayments (nowpayments.io → panel)
# OBLIGATORIA (mínimo 16 caracteres) — el servidor no arranca sin ella
NOWPAYMENTS_API_KEY=tu_api_key
NOWPAYMENTS_IPN_SECRET=tu_ipn_secret

# Base de datos PostgreSQL
# OBLIGATORIA (mínimo 16 caracteres) — el servidor no arranca sin ella
DATABASE_URL=postgres://usuario:contraseña@host:5432/nombre_db

# Panel de administración (/admin.html)
# OBLIGATORIA (mínimo 16 caracteres) — el servidor no arranca sin ella
ADMIN_PASSWORD=una_contraseña_larga_y_segura

# Servidor
PORT=3000
BASE_URL=http://localhost:3000
