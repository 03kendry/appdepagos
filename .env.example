# ══ PayPal (developer.paypal.com → Apps & Credentials) ══════════════════════
# OPCIONALES POR AHORA: la cuenta PayPal del socio aún no existe. Si faltan,
# el servidor arranca igual con un warning y el método PayPal aparece como
# "Próximamente" en la UI. El día que existan las credenciales, sigue el
# procedimiento exacto de RUNBOOK_NCP.md.
PAYPAL_CLIENT_ID=tu_client_id
PAYPAL_CLIENT_SECRET=tu_secret
PAYPAL_ENV=sandbox             # sandbox | live (alias legado: PAYPAL_MODE)
# ID del webhook registrado en la REST App (necesario para verificar firmas)
PAYPAL_WEBHOOK_ID=tu_webhook_id

# ══ PayPal NCP (pay links creados A MANO en el dashboard Business) ═══════════
# JSON inline o ruta a un archivo .json. Cada link debe tener el campo
# personalizado "Código de referencia" configurado en el dashboard.
# tipo: "fijo" (monto fijo del link) | "monto_abierto" (el cliente lo ingresa)
# Ejemplo:
# PAYPAL_NCP_LINKS_CONFIG=[{"id":"pl-10","nombre":"Pago 10 USD","monto":10,"moneda":"USD","url":"https://www.paypal.com/ncp/payment/XXXXXXXX","tipo":"fijo","activo":true},{"id":"pl-abierto","nombre":"Monto abierto","moneda":"USD","url":"https://www.paypal.com/ncp/payment/YYYYYYYY","tipo":"monto_abierto","activo":true}]
PAYPAL_NCP_LINKS_CONFIG=
NCP_ORDER_TTL_MINUTES=60       # expiración de órdenes NCP pendientes
NCP_MATCH_WINDOW_MINUTES=90    # ventana del matching heurístico (webhook/reconciliación)

# ══ NOWPayments (nowpayments.io → panel) ═════════════════════════════════════
# OBLIGATORIA (mínimo 16 caracteres) — el servidor no arranca sin ella
NOWPAYMENTS_API_KEY=tu_api_key
NOWPAYMENTS_IPN_SECRET=tu_ipn_secret

# ══ Base de datos PostgreSQL ═════════════════════════════════════════════════
# OBLIGATORIA (mínimo 16 caracteres) — el servidor no arranca sin ella
DATABASE_URL=postgres://usuario:contraseña@host:5432/nombre_db

# ══ Panel de administración (/admin.html) ════════════════════════════════════
# OBLIGATORIA (mínimo 16 caracteres) — el servidor no arranca sin ella
ADMIN_PASSWORD=una_contraseña_larga_y_segura

# ══ Servidor ═════════════════════════════════════════════════════════════════
PORT=3000
BASE_URL=http://localhost:3000
